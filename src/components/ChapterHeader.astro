---
// A chapter's centered header: city title with the shared blue underline, an
// optional uppercase region line, and an optional blurb. Split out of
// ChapterPage so the page composes sub-components rather than raw markup.
interface Props {
  city: string;
  region?: string;
  blurb?: string;
}
const { city, region, blurb } = Astro.props;
---

<header style="text-align: center; margin: var(--space-2xl) auto var(--space-xl); max-width: var(--text-width); padding: 0 var(--space-lg);">
  <span class="s-eyebrow">Harvard in Tech{region ? ` · ${region}` : ''}</span>
  <h1 class="s-title" style="margin-bottom: 0;">{city}</h1>
  {
    blurb ? (
      <p style="color: var(--color-muted); font-size: var(--text-lg); margin: var(--space-md) auto 0; max-width: var(--text-width);">
        {blurb}
      </p>
    ) : null
  }
</header>
