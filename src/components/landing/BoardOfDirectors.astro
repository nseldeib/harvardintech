---
// "Board of directors" (Atlas): a five-across grid of square avatars with a
// crimson underline and mono role labels. Members come from the editable `team`
// content collection; a member with no photo falls back to initials. When the
// list is empty the section shows a quiet "announced soon" note (production
// starts empty).
import { initials, type BoardMemberLike } from '../../lib/team';
import { withBase } from '../../lib/url';

interface Props {
  members?: BoardMemberLike[];
}
const { members = [] } = Astro.props;

const count = String(members.length).padStart(2, '0');
---

<section class="sec" id="board">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <span class="kick">Leadership</span>
        <h2>Board of directors</h2>
      </div>
      {members.length > 0 && <span class="kick">{count} directors</span>}
    </div>

    {
      members.length === 0 ? (
        <p style="color: var(--color-muted); font-family: var(--font-serif); font-size: 18px;">
          Our board will be announced soon.
        </p>
      ) : (
        <div class="board">
          {members.map((member) => (
            <div class="bm">
              <div class="av">
                {member.photo ? (
                  <img class="pho" src={withBase(member.photo)} alt={member.name} />
                ) : (
                  <span class="initials">{initials(member.name)}</span>
                )}
              </div>
              <div class="nm">{member.name}</div>
              <div class="ro">{member.role}</div>
            </div>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .board {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
  }
  .bm {
    text-align: center;
  }
  .av {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 4px;
    overflow: hidden;
    background: var(--paper-2);
    border-bottom: 3px solid var(--crimson);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pho {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .initials {
    font-size: 34px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink-3);
  }
  .nm {
    font-size: 16px;
    font-weight: 700;
    margin-top: 14px;
  }
  .ro {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin-top: 5px;
  }
  @media (max-width: 820px) {
    .board {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 520px) {
    .board {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
