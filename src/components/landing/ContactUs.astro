---
// "Contact us" (Atlas): an editorial closing section — kicker + headline, a
// serif invitation, and a row of social links (small icon + label) plus the
// contact email. Reads the editable socials + contact email from the settings
// singleton; the e-mail entry is synthesized so it always appears.
import { buildMailto } from '../../lib/mailto';
import { socialIconSrc } from '../../lib/socialIcon';
import type { SocialLink } from '../../lib/site';

interface Props {
  socials: readonly SocialLink[];
  email: string;
}
const { socials, email } = Astro.props;
const contactHref = buildMailto({ to: email, subject: 'Hello from the website' });

const links = [
  ...socials.map((s) => ({ label: s.label, url: s.url, icon: s.icon })),
  { label: 'E-mail', url: contactHref, icon: 'email' },
];
---

<section class="sec" id="contact">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <span class="kick">Say hello</span>
        <h2>Contact us</h2>
      </div>
    </div>

    <p class="contact-lede">
      We'd love to hear from you — reach out on any of these, or drop us a note.
    </p>
    <div class="contact-row">
      {
        links.map((link) => (
          <a class="contact-link" href={link.url} rel="noopener" aria-label={link.label}>
            {socialIconSrc(link.icon) && (
              <img class="contact-icon" src={socialIconSrc(link.icon)} alt="" width="22" height="22" loading="lazy" />
            )}
            <span class="contact-label">{link.label}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contact-lede {
    font-family: var(--font-serif);
    font-size: 19px;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0 0 26px;
    max-width: 52ch;
  }
  .contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 11px 18px;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: #fff;
    text-decoration: none;
    color: var(--ink);
    font-weight: 600;
    font-size: 14px;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .contact-link:hover {
    text-decoration: none;
    border-color: var(--crimson);
    transform: translateY(-1px);
  }
  .contact-icon {
    display: block;
    width: 22px;
    height: 22px;
    object-fit: contain;
    border-radius: 3px;
  }
</style>
