---
// "Support us" (Atlas): five ways to support, as crimson-edged cards that each
// open a pre-filled mailto to the organizer (via the shared buildMailto helper).
// Replaces the old circular-icon row with the editorial card grid used across
// the redesigned site.
import { buildMailto } from '../../lib/mailto';

interface Props {
  email?: string;
}
const { email = 'ben@harvardintech.com' } = Astro.props;

const options = [
  { label: 'Sponsor an event', subject: 'Sponsoring a Harvard Alumni in Tech event' },
  { label: 'Host us in your space', subject: 'Hosting a Harvard Alumni in Tech event' },
  { label: 'Share job opportunities', subject: 'Sharing a job opportunity' },
  { label: 'Speak at an event', subject: 'Speaking at a Harvard Alumni in Tech event' },
  { label: 'Volunteer your time', subject: 'Volunteering with Harvard Alumni in Tech' },
];
---

<section class="sec" id="support">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <span class="kick">Support the mission</span>
        <h2>Ways to support</h2>
      </div>
    </div>
    <div class="support-grid">
      {
        options.map((opt) => (
          <a class="sup" href={buildMailto({ to: email, subject: opt.subject })}>
            <span class="sup-l">{opt.label}</span>
            <span class="sup-go">Get in touch →</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .support-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
  }
  .sup {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 18px;
    min-height: 120px;
    background: var(--paper-2);
    border-left: 3px solid var(--crimson);
    padding: 20px 18px;
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .sup:hover {
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 12px 26px rgba(30, 26, 27, 0.1);
  }
  .sup-l {
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .sup-go {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--crimson);
  }
  @media (max-width: 900px) {
    .support-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .support-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
