---
// "Giving campaign" (Atlas crimson CTA band): the fundraising ask with Donate /
// Sponsor actions. No fabricated progress meter — real campaign totals can be
// added later via the CMS if desired; until then this is a clean call to give.
import { buildMailto } from '../../lib/mailto';

interface Props {
  email?: string;
  headline?: string;
  blurb?: string;
  donateUrl?: string;
}
const {
  email = 'ben@harvardintech.com',
  headline = 'Back the mission.',
  blurb = 'Your gift funds in-person events, new chapters, and our global community — keeping Harvard Alumni in Tech free and open to every alum in technology.',
  // No donation platform yet — "Donate" opens a giving inquiry email (same model
  // as Sponsorship). When a real donation link exists, pass it as `donateUrl`.
  donateUrl,
} = Astro.props as Props;

const donateHref = donateUrl ?? buildMailto({ to: email, subject: 'Supporting Harvard Alumni in Tech' });
const sponsorHref = buildMailto({ to: email, subject: 'Sponsoring Harvard Alumni in Tech' });
---

<section class="giving" id="giving">
  <div class="wrap giving-in">
    <div class="giving-copy">
      <span class="kick" style="color:#fff">Giving campaign</span>
      <h3>{headline}</h3>
      <p>{blurb}</p>
    </div>
    <div class="giving-actions">
      <a class="btn btn-solid" href={donateHref} rel="noopener">Donate</a>
      <a class="btn btn-out on-dark" href={sponsorHref}>Sponsorship</a>
    </div>
  </div>
</section>

<style>
  .giving {
    background: var(--crimson);
    color: #fff;
    border-bottom: 1px solid var(--line);
  }
  .giving-in {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: 40px;
    align-items: center;
    padding: 60px 48px;
  }
  .giving-copy h3 {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 8px 0 10px;
  }
  .giving-copy p {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.85);
    max-width: 52ch;
    margin: 0;
  }
  .giving-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .giving .btn-solid {
    background: #fff;
    color: var(--crimson);
  }
  .giving .btn-solid:hover {
    background: rgba(255, 255, 255, 0.9);
  }
  @media (max-width: 820px) {
    .giving-in {
      grid-template-columns: 1fr;
      padding: 48px 24px;
    }
    .giving-actions {
      justify-content: flex-start;
    }
  }
</style>
