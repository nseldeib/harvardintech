---
// "Upcoming events" (Atlas): the landing-page events section in the editorial
// idiom — a sec-head (kicker + heading), then either the event cards or the
// empty state. Empty state (production's day-one default) offers the two
// subscribe paths — the org's Luma calendar (primary) and the mailing list
// (secondary) — so a visitor with no events yet still has a next action.
import EventCard from '../EventCard.astro';
import type { EventLike } from '../../lib/events';
import { LUMA_CALENDAR_URL } from '../../lib/luma';

interface Props {
  events?: EventLike[];
  lumaUrl?: string;
  newsletterUrl?: string;
}
const {
  events = [],
  lumaUrl = LUMA_CALENDAR_URL,
  newsletterUrl = 'https://mailchi.mp/0222623e1169/fbrj32e9wb',
} = Astro.props;

const count = String(events.length).padStart(2, '0');
---

<section class="sec" id="events">
  <div class="wrap">
    <div class="sec-head">
      <div>
        <span class="kick">Calendar</span>
        <h2>Upcoming events</h2>
      </div>
      {events.length > 0 && <span class="kick">{count} scheduled</span>}
    </div>

    {
      events.length === 0 ? (
        <div class="ue-empty">
          <p>
            No upcoming events just yet — subscribe to our Luma calendar to be the
            first to know when the next one is announced.
          </p>
          <div class="ue-cta">
            <a class="btn btn-solid" href={lumaUrl} rel="noopener" target="_blank">
              Subscribe to our Luma calendar
            </a>
            <a class="btn btn-out" href={newsletterUrl} rel="noopener">
              Subscribe to our newsletter
            </a>
          </div>
        </div>
      ) : (
        <Fragment>
          <div class="ue-grid">
            {events.map((event) => (
              <EventCard event={event} variant="upcoming" />
            ))}
          </div>
          <div class="ue-cta" style="margin-top: 28px;">
            <a class="btn btn-solid" href={lumaUrl} rel="noopener" target="_blank">
              View full calendar on Luma
            </a>
          </div>
        </Fragment>
      )
    }
  </div>
</section>

<style>
  .ue-empty p {
    font-family: var(--font-serif);
    font-size: 19px;
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 56ch;
    margin: 0 0 24px;
  }
  .ue-grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .ue-cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
</style>
