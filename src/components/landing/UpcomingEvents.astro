---
// "UPCOMING EVENTS" — the landing-page section. Renders the `events` content
// collection as shared EventCards. Accepts a plain array so it works from
// getCollection() on the homepage and from isolated-component scenarios
// (empty / sparse / rich / long-title states).
import EventCard from '../EventCard.astro';
import type { EventLike } from '../../lib/events';

interface Props {
  events?: EventLike[];
  eventbriteUrl?: string;
}
const {
  events = [],
  eventbriteUrl = 'https://www.eventbrite.com/o/harvard-in-tech-17275560304',
} = Astro.props;
---

<section class="s-section" id="events">
  <div class="s-inner" style="text-align: center;">
    <h2 class="s-title">Upcoming Events</h2>
    {
      events.length === 0 ? (
        <p style="color: var(--color-muted);">
          No upcoming events right now — sign up for our mailing list to hear about the next one.
        </p>
      ) : (
        <div style="display: grid; gap: var(--space-lg); grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); max-width: 920px; margin: 0 auto;">
          {events.map((event) => (
            <EventCard event={event} variant="upcoming" />
          ))}
        </div>
      )
    }
    <div style="margin-top: var(--space-lg);">
      <a class="s-btn" href={eventbriteUrl} rel="noopener">View Upcoming Events</a>
    </div>
  </div>
</section>
