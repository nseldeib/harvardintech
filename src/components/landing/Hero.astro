---
// Top hero "Harvard Alumni in Tech" — redesigned into a modern editorial hero:
// a kicker label above a large display headline, the mission paragraph
// constrained to a readable measure, and primary + secondary CTAs. The
// background photo keeps its proxy-safe <img> + softened parallax, with a
// directional gradient overlay (instead of the old flat black wash) for depth
// and legibility.
import { withBase } from '../../lib/url';
interface Props {
  description?: string;
  subscribeUrl?: string;
  eventsUrl?: string;
  image?: string;
}
const {
  description = 'We are the official Harvard Alumni Group for technology — encouraging innovation, providing Harvard alumni technologists with resources and networks, and growing chapters in cities around the world.',
  subscribeUrl = 'https://mailchi.mp/0222623e1169/fbrj32e9wb',
  eventsUrl = '/events',
  image = '/images/bg/hero-bg.jpg',
} = Astro.props;
---

<section class="hero" id="about" data-parallax-root>
  <div class="hero-bg">
    <img
      src={withBase(image)}
      alt=""
      data-parallax
      style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-inner">
    <span class="s-eyebrow hero-eyebrow">Harvard Alumni Group for Technology</span>
    <h1 class="hero-title">Harvard Alumni in Tech</h1>
    <p class="hero-text">{description}</p>
    <div class="hero-cta">
      <a class="s-btn" href={subscribeUrl} rel="noopener">Join our mailing list</a>
      <a class="s-btn s-btn--on-dark" href={withBase(eventsUrl)}>See upcoming events</a>
    </div>
  </div>
</section>

<script>
  import { initParallax } from '../../lib/parallax';
  initParallax();
</script>

<style>
  .hero {
    position: relative;
    box-sizing: border-box;
    /* Fill the first screen below the header. `min-height` (not `height`) so
       tall content never clips on short screens; `svh` avoids the mobile
       address-bar jump, with a `vh` fallback for browsers without `svh`. */
    min-height: calc(100vh - var(--header-height));
    min-height: calc(100svh - var(--header-height));
    padding: clamp(2rem, 6vw, 6rem) var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }
  /* Directional gradient — darker at the lower-left where the text sits,
     fading to a lighter wash top-right for depth. */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(105deg, rgba(15, 16, 19, 0.82) 0%, rgba(15, 16, 19, 0.55) 42%, rgba(15, 16, 19, 0.18) 100%),
      linear-gradient(0deg, rgba(15, 16, 19, 0.45) 0%, rgba(15, 16, 19, 0) 55%);
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 760px;
    color: #fff;
  }
  .hero-eyebrow {
    color: #ff8fa3;
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    color: #fff;
    font-size: var(--text-5xl);
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin: 0 0 1.25rem;
  }
  .hero-text {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 400;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.92);
    max-width: 60ch;
    margin: 0 0 2rem;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  @media (max-width: 640px) {
    .hero {
      padding: 3rem 1.5rem;
    }
    .hero-text {
      font-size: 1.05rem;
    }
    .hero-cta {
      width: 100%;
    }
    .hero-cta :global(.s-btn) {
      flex: 1 1 auto;
      justify-content: center;
    }
  }
</style>
