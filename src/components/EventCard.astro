---
// A single event card. `variant` controls upcoming (accent date, "Learn more"
// link) vs past (faint date, dimmed, no link) styling. Shared by the landing
// UpcomingEvents section and the /events page so all event cards stay identical.
// Redesigned onto the shared `.s-card` look: elevation, hover lift, a crimson
// date rule, and a clearer "Learn more" affordance.
import { formatEventDate, type EventLike } from '../lib/events';

interface Props {
  event: EventLike;
  variant?: 'upcoming' | 'past';
}
const { event, variant = 'upcoming' } = Astro.props;
const isPast = variant === 'past';
---

<article class:list={['event-card', 's-card', { 'event-card--past': isPast }]}>
  <time class="event-date">{formatEventDate(event.date)}</time>
  <h3 class="event-title">{event.title}</h3>
  {event.location ? <p class="event-location">{event.location}</p> : null}
  {event.description ? <p class="event-desc">{event.description}</p> : null}
  {
    !isPast && event.link ? (
      <a class="event-link" href={event.link} rel="noopener">
        Learn more <span aria-hidden="true">→</span>
      </a>
    ) : null
  }
</article>

<style>
  .event-card {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    text-align: left;
  }
  .event-card--past {
    opacity: 0.78;
  }
  .event-date {
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }
  .event-card--past .event-date {
    color: var(--color-faint);
  }
  .event-title {
    margin: var(--space-sm) 0 0.4rem;
    font-size: var(--text-xl);
    line-height: 1.2;
  }
  .event-location {
    color: var(--color-faint);
    margin: 0 0 var(--space-sm);
    font-size: 0.9rem;
  }
  .event-desc {
    color: var(--color-muted);
    margin: 0 0 var(--space-md);
  }
  .event-card--past .event-desc {
    margin-bottom: 0;
  }
  .event-link {
    margin-top: auto;
    font-weight: 600;
    color: var(--color-accent-dark);
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
  }
  .event-link span {
    transition: transform var(--dur-fast) var(--ease);
  }
  .event-link:hover {
    color: var(--color-primary);
    text-decoration: none;
  }
  .event-link:hover span {
    transform: translateX(3px);
  }
</style>
