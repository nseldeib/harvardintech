---
// A single event card. `variant` controls upcoming (accent date, "Learn more"
// link) vs past (faint date, dimmed, no link) styling. Shared by the landing
// UpcomingEvents section and the /events page so all event cards stay identical.
import { formatEventDate, type EventLike } from '../lib/events';

interface Props {
  event: EventLike;
  variant?: 'upcoming' | 'past';
}
const { event, variant = 'upcoming' } = Astro.props;
const isPast = variant === 'past';
---

<article
  style={`border: 1px solid var(--color-border); border-radius: var(--radius); padding: var(--space-lg); display: flex; flex-direction: column; text-align: left;${isPast ? ' opacity: 0.85;' : ''}`}
>
  <time
    style={`font-weight: 500; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; color: ${isPast ? 'var(--color-faint)' : 'var(--color-accent)'};`}
  >
    {formatEventDate(event.date)}
  </time>
  <h3 style="margin: var(--space-sm) 0; font-size: 1.2rem;">{event.title}</h3>
  {
    event.location ? (
      <p style="color: var(--color-faint); margin: 0 0 var(--space-sm); font-size: 0.9rem;">
        {event.location}
      </p>
    ) : null
  }
  {
    event.description ? (
      <p style={`color: var(--color-muted); margin: 0${isPast ? '' : ' 0 var(--space-md)'};`}>
        {event.description}
      </p>
    ) : null
  }
  {
    !isPast && event.link ? (
      <a href={event.link} rel="noopener" style="margin-top: auto; font-weight: 500;">
        Learn more →
      </a>
    ) : null
  }
</article>
