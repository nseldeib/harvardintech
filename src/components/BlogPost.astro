---
// A single long-form blog article: a back link, an eyebrow + display title, the
// publish date, and the rendered markdown body (passed via the default slot).
// Extracted from src/pages/blog/[slug].astro so the route file is pure
// composition (BaseLayout > BlogPost > <Content />) and the article layout can
// be driven by an isolated-component scenario.
import { withBase } from '../lib/url';

interface Props {
  title: string;
  date: Date;
}
const { title, date } = Astro.props;
const dateLabel = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post s-section">
  <div class="post-inner">
    <a class="post-back" href={withBase('/')}>
      <span aria-hidden="true">←</span> All posts
    </a>
    <header class="post-head">
      <span class="s-eyebrow">From the blog</span>
      <h1 class="post-title">{title}</h1>
      <time class="post-date" datetime={date.toISOString()}>{dateLabel}</time>
    </header>
    <div class="post-body">
      <slot />
    </div>
  </div>
</article>

<style>
  .post-inner {
    max-width: var(--text-width);
    margin: 0 auto;
  }
  .post-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-muted);
    margin-bottom: var(--space-lg);
  }
  .post-back:hover {
    color: var(--color-primary);
    text-decoration: none;
  }
  .post-head {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }
  .post-title {
    font-size: var(--text-4xl);
    line-height: 1.05;
    margin: 0 0 var(--space-md);
  }
  .post-date {
    color: var(--color-faint);
    font-size: 0.95rem;
  }
  /* Long-form article body: comfortable measure, refined headings + links. */
  .post-body {
    font-size: 1.12rem;
    line-height: 1.8;
    color: var(--color-fg);
  }
  .post-body :global(h2) {
    font-size: var(--text-2xl);
    margin: 2.4rem 0 0.8rem;
  }
  .post-body :global(h3) {
    font-size: var(--text-xl);
    margin: 2rem 0 0.6rem;
  }
  .post-body :global(p) {
    margin: 0 0 1.4rem;
  }
  .post-body :global(a) {
    color: var(--color-accent-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .post-body :global(a:hover) {
    color: var(--color-primary);
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 1.4rem;
    padding-left: 1.4rem;
  }
  .post-body :global(li) {
    margin: 0 0 0.5rem;
  }
  .post-body :global(blockquote) {
    margin: 1.8rem 0;
    padding: 0.4rem 0 0.4rem 1.4rem;
    border-left: 4px solid var(--color-primary);
    color: var(--color-muted);
    font-style: italic;
  }
  .post-body :global(img) {
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }
  .post-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--color-bg-soft);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
  }
  .post-body :global(pre) {
    background: var(--color-bg-dark);
    color: var(--color-on-dark);
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    overflow-x: auto;
  }
  .post-body :global(pre code) {
    background: none;
    padding: 0;
  }
</style>
