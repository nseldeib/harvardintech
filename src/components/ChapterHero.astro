---
// Full-bleed city header for a chapter page — faithful to harvardintech.com:
// a background photo with a dark overlay and centered light text, an uppercase
// "HARVARD IN TECH <CITY>" title (the "fresh" theme's flanking-rule treatment,
// mirroring landing/Hero.astro) and the `tagline` subtitle beneath it. The
// background is rendered as an <img> (survives the preview reverse-proxy /
// base-path rewrite). When `heroImage` is absent we fall back to the original
// centered ChapterHeader so a chapter with no image still renders.
import ChapterHeader from './ChapterHeader.astro';
import { withBase } from '../lib/url';

interface Props {
  city: string;
  region?: string;
  blurb?: string;
  heroImage?: string;
  tagline?: string;
}
const { city, region, blurb, heroImage, tagline } = Astro.props;
---

{
  heroImage ? (
    <section class="chapter-hero">
      <div class="chapter-hero-bg">
        <img
          src={withBase(heroImage)}
          alt=""
          style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;"
        />
        <div class="chapter-hero-overlay" />
      </div>
      <div class="chapter-hero-inner">
        <span class="s-eyebrow chapter-hero-eyebrow">Harvard in Tech</span>
        <h1 class="chapter-hero-title">{city}</h1>
        {tagline ? <p class="chapter-hero-tagline">{tagline}</p> : null}
      </div>
    </section>
  ) : (
    <ChapterHeader city={city} region={region} blurb={blurb} />
  )
}

<style>
  .chapter-hero {
    position: relative;
    box-sizing: border-box;
    /* Fill the first screen below the header, like the live chapter pages.
       `min-height` (not `height`) so content never clips on short screens;
       `svh` avoids the mobile address-bar jump, with a `vh` fallback. */
    min-height: calc(100vh - var(--header-height));
    min-height: calc(100svh - var(--header-height));
    padding: clamp(2rem, 6vw, 6rem) var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
  }
  .chapter-hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }
  .chapter-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(105deg, rgba(15, 16, 19, 0.82) 0%, rgba(15, 16, 19, 0.55) 42%, rgba(15, 16, 19, 0.18) 100%),
      linear-gradient(0deg, rgba(15, 16, 19, 0.45) 0%, rgba(15, 16, 19, 0) 55%);
  }
  .chapter-hero-inner {
    position: relative;
    z-index: 2;
    max-width: 760px;
    color: #fff;
  }
  .chapter-hero-eyebrow {
    color: #ff8fa3;
  }
  .chapter-hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    color: #fff;
    font-size: var(--text-5xl);
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin: 0;
  }
  .chapter-hero-tagline {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 400;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.92);
    max-width: 56ch;
    margin: 1.5rem 0 0;
  }

  @media (max-width: 640px) {
    .chapter-hero {
      padding: 3rem 1.5rem;
    }
    .chapter-hero-tagline {
      font-size: 1.05rem;
    }
  }
</style>
