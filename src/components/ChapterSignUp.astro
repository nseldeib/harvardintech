---
// The teal "Sign Up" band from the live chapter pages: a light blue section
// with a flanking-rule "Sign Up" heading, a "Join the Harvard in Tech
// Community" line, and a Subscribe pill. Defaults to the same MailChimp signup
// the landing Hero uses; accepts an optional `subscribeUrl` for future
// per-chapter overrides.
interface Props {
  subscribeUrl?: string;
}
const { subscribeUrl = 'https://mailchi.mp/0222623e1169/fbrj32e9wb' } = Astro.props;
---

<section class="s-section" id="sign-up" style="background: var(--color-bg-blue);">
  <div class="s-narrow s-reveal" style="text-align: center;">
    <span class="s-eyebrow">Stay in the loop</span>
    <h2 class="s-title">Sign Up</h2>
    <p style="font-size: var(--text-lg); color: var(--color-muted); margin: 0 0 var(--space-lg);">
      Join the Harvard in Tech Community
    </p>
    <a class="s-btn" href={subscribeUrl} rel="noopener">Subscribe</a>
  </div>
</section>
