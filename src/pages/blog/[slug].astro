---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPost from '../../components/BlogPost.astro';

// Static output needs every dynamic route enumerated at build time.
// `getStaticPaths` turns each blog entry into a pre-rendered `/blog/<id>` page.
// Content Layer entries key on `id` (the file stem) — the old `slug`.
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props as Props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title}>
  <BlogPost title={post.data.title} date={post.data.date}>
    <Content />
  </BlogPost>
</BaseLayout>
