---
// /admin — the CRM dashboard. Loads the entry count for each editable content
// collection (from the same `src/content/*` the public site renders) and
// composes the admin shell from section components. The actual editing UI is
// Sveltia at /admin/editor/, reached via the buttons the sections render.
import { getCollection } from 'astro:content';
import AdminLayout from '../../layouts/AdminLayout.astro';
import DashboardSummary from '../../components/admin/DashboardSummary.astro';
import DeployStatus from '../../components/admin/DeployStatus.astro';
import CollectionCountGrid from '../../components/admin/CollectionCountGrid.astro';
import SignInGuide from '../../components/admin/SignInGuide.astro';
import { ADMIN_COLLECTIONS, dashboardTotals } from '../../lib/adminDashboard';
import { withBase } from '../../lib/url';

const cards = await Promise.all(
  ADMIN_COLLECTIONS.map(async (c) => ({
    ...c,
    count: (await getCollection(c.collection)).length,
  })),
);
const { total, collectionCount } = dashboardTotals(cards);
// Link to index.html explicitly: GitHub Pages serves /admin/editor/ via its
// directory index, but the Astro dev server (and codeyam preview) does not, so
// the bare directory path 404s locally. index.html resolves in both.
const editorHref = withBase('/admin/editor/index.html');
---

<AdminLayout title="Dashboard">
  <DeployStatus />
  <DashboardSummary total={total} collectionCount={collectionCount} editorHref={editorHref} />
  <CollectionCountGrid cards={cards} editorHref={editorHref} />
  <SignInGuide />
</AdminLayout>
