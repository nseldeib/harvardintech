---
import Greeting from '../../components/Greeting.tsx';
import EmbedForm from '../../components/EmbedForm.astro';
import EventsPage from '../../components/EventsPage.astro';
import ChapterPage from '../../components/ChapterPage.astro';
import ChapterHero from '../../components/ChapterHero.astro';
import ChapterEvents from '../../components/ChapterEvents.astro';
import ChapterSignUp from '../../components/ChapterSignUp.astro';
import ChapterConnect from '../../components/ChapterConnect.astro';
import CollectionCountCard from '../../components/admin/CollectionCountCard.astro';
import DashboardSummary from '../../components/admin/DashboardSummary.astro';
import DeployStatus from '../../components/admin/DeployStatus.astro';
import AdminGatePrompt from '../../components/admin/AdminGatePrompt.astro';
import BoardMemberCard from '../../components/BoardMemberCard.astro';
import ContactUs from '../../components/landing/ContactUs.astro';
import type { BannerView } from '../../lib/deployStatus';
import '../../styles/tokens.css';

// Component-isolation harness. codeyam captures a single component in isolation
// by navigating to `/isolated-components/<Name>` and screenshotting the
// `#codeyam-capture` wrapper. Add new entries to make a component isolable.
//
// Two flavors: React islands (hydrated via `client:load`) and static Astro
// components (server-rendered, no hydration). Static output enumerates routes
// at build time, so every name is a pre-rendered page via `getStaticPaths`.
const islands = {
  Greeting: { Component: Greeting, props: { name: 'Preview', subtitle: 'Isolated island' } },
} as const;

// Static Astro components. A prerendered page can't read `?s=` query params at
// render time, so each visual state is its own route name (`EmbedForm`,
// `EmbedForm-Embedded`, `EmbedForm-Unconfigured`) enumerated in getStaticPaths.
const embedFormStates = {
  Configured: {
    action: 'https://harvardintech.us1.list-manage.com/subscribe/post?u=abc123&id=def456',
    title: 'Join the Harvard in Tech newsletter',
    buttonLabel: 'Subscribe',
  },
  Embedded: {
    embedUrl: 'https://docs.google.com/forms/d/e/EXAMPLE_FORM_ID/viewform?embedded=true',
    title: 'RSVP — Harvard in Tech Summit 2026',
  },
  Unconfigured: {
    title: 'Subscribe',
  },
} as const;

// EventsPage states. `now` is fixed so the Upcoming/Past split is deterministic
// regardless of the build date. The Empty state proves the no-events fallback.
const SAMPLE_EVENTS = [
  {
    title: 'Harvard in Tech Summit 2026',
    date: '2026-09-24',
    location: 'New York, NY',
    description: 'Our flagship annual gathering of Harvard founders, operators, and investors.',
    link: 'https://www.harvardintech.com/events/summit-2026',
  },
  {
    title: 'Founders & Investors Mixer — San Francisco',
    date: '2026-07-15',
    location: 'San Francisco, CA',
    description: 'An evening connecting Harvard alumni founders with active investors across the Bay Area.',
    link: 'https://www.harvardintech.com/events/sf-mixer',
  },
  {
    title: 'Spring Founder Dinner — NYC',
    date: '2026-03-12',
    location: 'New York, NY',
    description: 'An intimate dinner with Harvard alumni founders and operators.',
    link: 'https://www.harvardintech.com/events/spring-founder-dinner',
  },
];
// NOTE: no `as const` — these fixtures feed components whose props are mutable
// arrays (`EventLike[]`), so a deeply-readonly literal would fail the type check.
const eventsPageStates = {
  Default: { events: SAMPLE_EVENTS, now: '2026-06-13' },
  Empty: { events: [] as typeof SAMPLE_EVENTS, now: '2026-06-13' },
};

// ChapterPage states: a full NYC-style chapter — full-bleed city hero, Sign Up
// band, leads/body/links, gallery, and Connect With Us — vs a sparse one
// (city + region only, NO heroImage) proving the centered-header fallback and
// the missing-optional layout.
const chapterPageStates = {
  Default: {
    city: 'New York City',
    region: 'New York, NY',
    blurb: 'Our founding chapter and largest community, hosting monthly mixers, founder dinners, and the annual Harvard in Tech Summit.',
    heroImage: '/images/chapters/nyc.jpg',
    tagline: 'We are the New York Chapter of Harvard in Tech.',
    showGallery: true,
    leads: [
      { name: 'Jessica Li', role: 'Chapter Lead' },
      { name: 'Ben Wei', role: 'Events' },
    ],
    links: [
      { label: 'Join the NYC WhatsApp', url: 'https://chat.whatsapp.com/harvardintech-nyc' },
      { label: 'NYC events on Eventbrite', url: 'https://www.eventbrite.com/o/harvard-in-tech-17275560304' },
    ],
  },
  Sparse: {
    city: 'Japan',
    region: 'Tokyo',
  },
};

// ChapterHero states: the full-bleed city header WITH a hero image + tagline
// vs the no-image Fallback that degrades to the centered ChapterHeader.
const chapterHeroStates = {
  Default: {
    city: 'New York City',
    region: 'New York, NY',
    heroImage: '/images/chapters/nyc.jpg',
    tagline: 'We are the New York Chapter of Harvard in Tech.',
  },
  Fallback: {
    city: 'Japan',
    region: 'Tokyo',
    blurb: 'Our first international chapter.',
  },
};

// ChapterEvents states: the per-chapter "Upcoming Events in {city}" section.
// Default shows a rich, multi-card list (mirrors the SF chapter page); Empty
// passes no events to prove the guard renders NOTHING (no empty heading/block).
const SAMPLE_CHAPTER_EVENTS = [
  {
    title: 'Founders & Investors Mixer — San Francisco',
    date: '2026-07-15',
    location: 'San Francisco, CA',
    description: 'An evening connecting Harvard alumni founders with active investors across the Bay Area.',
    link: 'https://www.harvardintech.com/events/sf-mixer',
  },
  {
    title: 'SF Chapter Summer Social',
    date: '2026-08-20',
    location: 'San Francisco, CA',
    description: 'Casual drinks and conversation for Bay Area alumni building in tech.',
    link: 'https://www.harvardintech.com/events/sf-summer-social',
  },
];
const chapterEventsStates = {
  Default: { events: SAMPLE_CHAPTER_EVENTS, city: 'San Francisco' },
  Empty: { events: [] as typeof SAMPLE_CHAPTER_EVENTS, city: 'Los Angeles' },
};

// ChapterConnect states: Default reads the global settings contact email;
// Email passes a per-chapter `email` override (the SF chapter's address),
// proving the override branch wins over the settings fallback.
const chapterConnectStates = {
  Default: {},
  Email: { email: 'risdhillon@harvardintech.com' },
} as const;

// CollectionCountCard states: a populated count (links into the editor) vs an
// empty collection (count 0 → the "No entries yet" note). `editorHref` mirrors
// the real dashboard link.
const ADMIN_EDITOR_HREF = '/admin/editor/index.html';
const collectionCountCardStates = {
  Default: { collection: 'events' as const, label: 'Events', count: 3, editorHref: ADMIN_EDITOR_HREF },
  Empty: { collection: 'blog' as const, label: 'Blog', count: 0, editorHref: ADMIN_EDITOR_HREF },
};

// DashboardSummary states: a populated summary (total + collection count) vs the
// empty-state nudge shown when there is no content at all.
const dashboardSummaryStates = {
  Default: { total: 14, collectionCount: 5, editorHref: ADMIN_EDITOR_HREF },
  Empty: { total: 0, collectionCount: 5, editorHref: ADMIN_EDITOR_HREF },
};

// DeployStatus states: one per banner state of the CMS deploy-status banner.
// All render `mode="static"` so the client island never polls in isolation —
// each fixed `BannerView` is captured exactly as the state machine produces it.
const deployStatusStates: Record<string, BannerView> = {
  Default: {
    state: 'deploying',
    title: 'Deploying…',
    detail: 'Publishing your change — this usually takes about a minute.',
  },
  Building: {
    state: 'building',
    title: 'Building your change…',
    detail: 'GitHub is building the site. It will be live shortly.',
  },
  Live: {
    state: 'live',
    title: '🎉 Your change is live',
    detail: 'The site has finished publishing and is serving your edit.',
    link: { href: '/', label: 'View live site' },
  },
  Failed: {
    state: 'failed',
    title: 'Deploy failed',
    detail: 'The publish run did not complete. Your change is saved but not yet live.',
    link: { href: 'https://github.com/jaredcosulich/harvardintech/actions', label: 'View build logs' },
  },
  Slow: {
    state: 'slow',
    title: 'Still deploying…',
    detail: 'This is taking longer than usual. Large changes can take a few extra minutes.',
  },
  Idle: {
    state: 'idle',
    title: 'Up to date',
    detail: 'Last deployed 2 minutes ago.',
    link: { href: '/', label: 'View live site' },
  },
  Local: {
    state: 'idle',
    title: 'Local preview',
    detail: 'Changes publish when committed and pushed to the live site.',
  },
};

// BoardMemberCard states: a member WITH a photo (the real board headshot) vs a
// member with NO photo, proving the initials-avatar fallback branch.
const boardMemberCardStates = {
  Default: {
    member: { name: 'Krysia Lenzo', role: "Executive Director · Harvard C'12", photo: '/images/team/krysia-lenzo.png', order: 3 },
  },
  Initials: {
    member: { name: 'Ada Lovelace', role: "Advisor · Harvard C'15", order: 6 },
  },
} as const;

// ContactUs states: the live "CONTACT US" section with its real downloaded
// social icons (Twitter / E-mail / Facebook) rendered icon-over-label. The
// e-mail entry is always synthesized from `email`, so the Default state shows
// all three icons exactly as on harvardintech.com.
const contactUsStates = {
  Default: {
    socials: [
      { label: 'Twitter', url: 'https://twitter.com/harvardintech', icon: 'twitter' },
      { label: 'Facebook', url: 'https://facebook.com/harvardintech', icon: 'facebook' },
      { label: 'Email', url: 'mailto:ben@harvardintech.com', icon: 'email' },
    ],
    email: 'ben@harvardintech.com',
  },
} as const;

export async function getStaticPaths() {
  // getStaticPaths runs in an isolated scope and cannot reference the
  // module-level consts — enumerate route names inline.
  return [
    { params: { name: 'Greeting' } },
    { params: { name: 'EmbedForm' } },
    { params: { name: 'EmbedForm-Embedded' } },
    { params: { name: 'EmbedForm-Unconfigured' } },
    { params: { name: 'EventsPage' } },
    { params: { name: 'EventsPage-Empty' } },
    { params: { name: 'ChapterPage' } },
    { params: { name: 'ChapterPage-Sparse' } },
    { params: { name: 'ChapterHero' } },
    { params: { name: 'ChapterHero-Fallback' } },
    { params: { name: 'ChapterEvents' } },
    { params: { name: 'ChapterEvents-Empty' } },
    { params: { name: 'ChapterSignUp' } },
    { params: { name: 'ChapterConnect' } },
    { params: { name: 'ChapterConnect-Email' } },
    { params: { name: 'CollectionCountCard' } },
    { params: { name: 'CollectionCountCard-Empty' } },
    { params: { name: 'DashboardSummary' } },
    { params: { name: 'DashboardSummary-Empty' } },
    { params: { name: 'DeployStatus' } },
    { params: { name: 'DeployStatus-Building' } },
    { params: { name: 'DeployStatus-Live' } },
    { params: { name: 'DeployStatus-Failed' } },
    { params: { name: 'DeployStatus-Slow' } },
    { params: { name: 'DeployStatus-Idle' } },
    { params: { name: 'DeployStatus-Local' } },
    { params: { name: 'BoardMemberCard' } },
    { params: { name: 'BoardMemberCard-Initials' } },
    { params: { name: 'AdminGatePrompt' } },
    { params: { name: 'AdminGatePrompt-Empty' } },
    { params: { name: 'ContactUs' } },
  ];
}

const { name } = Astro.params;
// The `islands` registry above holds each hydrated island's preview props. The
// island component itself is rendered DIRECTLY in the template below (not
// through a variable). Astro generates a `client:*` hydration script by
// statically tracing the rendered component back to its import; a component
// referenced through a runtime variable (`<Island />`) can't be traced and
// fails the static build with `[NoMatchingImport]`. Adding a hydrated island
// therefore means BOTH a registry entry here AND a direct render branch.

// Resolve the EmbedForm visual state from the route name suffix.
let embedFormProps: (typeof embedFormStates)[keyof typeof embedFormStates] | null = null;
if (name && name.startsWith('EmbedForm')) {
  const stateKey = (name === 'EmbedForm' ? 'Configured' : name.slice('EmbedForm-'.length)) as keyof typeof embedFormStates;
  embedFormProps = embedFormStates[stateKey] ?? embedFormStates.Configured;
}

let eventsPageProps: (typeof eventsPageStates)[keyof typeof eventsPageStates] | null = null;
if (name && name.startsWith('EventsPage')) {
  const stateKey = (name === 'EventsPage' ? 'Default' : name.slice('EventsPage-'.length)) as keyof typeof eventsPageStates;
  eventsPageProps = eventsPageStates[stateKey] ?? eventsPageStates.Default;
}

let chapterPageProps: (typeof chapterPageStates)[keyof typeof chapterPageStates] | null = null;
if (name && name.startsWith('ChapterPage')) {
  const stateKey = (name === 'ChapterPage' ? 'Default' : name.slice('ChapterPage-'.length)) as keyof typeof chapterPageStates;
  chapterPageProps = chapterPageStates[stateKey] ?? chapterPageStates.Default;
}

// ChapterHero resolves its state from the route suffix; ChapterSignUp /
// ChapterConnect are single-state (the latter reads the settings singleton).
let chapterHeroProps: (typeof chapterHeroStates)[keyof typeof chapterHeroStates] | null = null;
if (name && name.startsWith('ChapterHero')) {
  const stateKey = (name === 'ChapterHero' ? 'Default' : name.slice('ChapterHero-'.length)) as keyof typeof chapterHeroStates;
  chapterHeroProps = chapterHeroStates[stateKey] ?? chapterHeroStates.Default;
}

// ChapterEvents resolves its state from the route suffix (Default rich list vs
// Empty no-events guard).
let chapterEventsProps: (typeof chapterEventsStates)[keyof typeof chapterEventsStates] | null = null;
if (name && name.startsWith('ChapterEvents')) {
  const stateKey = (name === 'ChapterEvents' ? 'Default' : name.slice('ChapterEvents-'.length)) as keyof typeof chapterEventsStates;
  chapterEventsProps = chapterEventsStates[stateKey] ?? chapterEventsStates.Default;
}

const isChapterSignUp = name === 'ChapterSignUp';

// ChapterConnect resolves Default (settings email) vs Email (per-chapter override).
let chapterConnectProps: (typeof chapterConnectStates)[keyof typeof chapterConnectStates] | null = null;
if (name && name.startsWith('ChapterConnect')) {
  const stateKey = (name === 'ChapterConnect' ? 'Default' : name.slice('ChapterConnect-'.length)) as keyof typeof chapterConnectStates;
  chapterConnectProps = chapterConnectStates[stateKey] ?? chapterConnectStates.Default;
}

let collectionCountCardProps: (typeof collectionCountCardStates)[keyof typeof collectionCountCardStates] | null = null;
if (name && name.startsWith('CollectionCountCard')) {
  const stateKey = (name === 'CollectionCountCard' ? 'Default' : name.slice('CollectionCountCard-'.length)) as keyof typeof collectionCountCardStates;
  collectionCountCardProps = collectionCountCardStates[stateKey] ?? collectionCountCardStates.Default;
}

let dashboardSummaryProps: (typeof dashboardSummaryStates)[keyof typeof dashboardSummaryStates] | null = null;
if (name && name.startsWith('DashboardSummary')) {
  const stateKey = (name === 'DashboardSummary' ? 'Default' : name.slice('DashboardSummary-'.length)) as keyof typeof dashboardSummaryStates;
  dashboardSummaryProps = dashboardSummaryStates[stateKey] ?? dashboardSummaryStates.Default;
}

let deployStatusBanner: BannerView | null = null;
if (name && name.startsWith('DeployStatus')) {
  const stateKey = name === 'DeployStatus' ? 'Default' : name.slice('DeployStatus-'.length);
  deployStatusBanner = deployStatusStates[stateKey] ?? deployStatusStates.Default;
}

let boardMemberCardProps: (typeof boardMemberCardStates)[keyof typeof boardMemberCardStates] | null = null;
if (name && name.startsWith('BoardMemberCard')) {
  const stateKey = (name === 'BoardMemberCard' ? 'Default' : name.slice('BoardMemberCard-'.length)) as keyof typeof boardMemberCardStates;
  boardMemberCardProps = boardMemberCardStates[stateKey] ?? boardMemberCardStates.Default;
}

// AdminGatePrompt: the masked /admin passcode overlay. The default route shows a
// pre-filled password rendered as dots (demonstrating the masking the real
// production-only gate provides); the `-Empty` route shows the initial, untouched
// prompt the visitor first sees.
const adminGatePromptValue = name === 'AdminGatePrompt' ? 'harvardintech-admin'
  : name === 'AdminGatePrompt-Empty' ? ''
  : null;
const isAdminGatePrompt = adminGatePromptValue !== null;

let contactUsProps: (typeof contactUsStates)[keyof typeof contactUsStates] | null = null;
if (name && name.startsWith('ContactUs')) {
  const stateKey = (name === 'ContactUs' ? 'Default' : name.slice('ContactUs-'.length)) as keyof typeof contactUsStates;
  contactUsProps = contactUsStates[stateKey] ?? contactUsStates.Default;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Isolated: {name}</title>
  </head>
  <body>
    <div id="codeyam-capture" style="padding: var(--space-lg);">
      {
        name === 'Greeting' ? (
          <Greeting {...islands.Greeting.props} client:load />
        ) : embedFormProps ? (
          <EmbedForm {...embedFormProps} />
        ) : eventsPageProps ? (
          <EventsPage {...eventsPageProps} />
        ) : chapterPageProps ? (
          <ChapterPage {...chapterPageProps}>
            <p>
              A representative "about this chapter" paragraph rendered in the
              markdown body slot, so the isolated capture matches the real route.
            </p>
          </ChapterPage>
        ) : chapterHeroProps ? (
          <ChapterHero {...chapterHeroProps} />
        ) : chapterEventsProps ? (
          <ChapterEvents {...chapterEventsProps} />
        ) : isChapterSignUp ? (
          <ChapterSignUp />
        ) : chapterConnectProps ? (
          <ChapterConnect {...chapterConnectProps} />
        ) : collectionCountCardProps ? (
          <div style="width: 240px; background: var(--color-bg-soft); padding: var(--space-md);">
            <CollectionCountCard {...collectionCountCardProps} />
          </div>
        ) : dashboardSummaryProps ? (
          <div style="width: 760px; max-width: 100%; background: var(--color-bg-soft); padding: var(--space-lg);">
            <DashboardSummary {...dashboardSummaryProps} />
          </div>
        ) : deployStatusBanner ? (
          <div style="width: 760px; max-width: 100%; background: var(--color-bg-soft); padding: var(--space-lg);">
            <DeployStatus initialBanner={deployStatusBanner} mode="static" />
          </div>
        ) : boardMemberCardProps ? (
          <div style="width: 200px;">
            <BoardMemberCard {...boardMemberCardProps} />
          </div>
        ) : isAdminGatePrompt ? (
          <div style="width: 640px; max-width: 100%;">
            <AdminGatePrompt value={adminGatePromptValue} />
          </div>
        ) : contactUsProps ? (
          <div style="width: 960px; max-width: 100%;">
            <ContactUs {...contactUsProps} />
          </div>
        ) : (
          <p>Unknown component: {name}</p>
        )
      }
    </div>
  </body>
</html>
