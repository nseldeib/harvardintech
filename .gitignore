# build output
dist/
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# environment variables
.env
.env.production

# macOS
.DS_Store

# process crash dumps
core
core.*

# editor
.vscode/*
!.vscode/extensions.json
.idea/

# python (compiled bytecode caches for the .claude/hooks/*.py scripts —
# regenerated automatically from source, version-specific, not source of truth)
__pycache__/
*.pyc

# codeyam ephemeral artifacts. The test-cache under .codeyam/ is deliberately
# NOT ignored — it is load-bearing and served to the UI on fresh clones.
test-results/
.codeyam/logs/
.codeyam/results-shown.json

# CodeYam - local runtime state
playwright-report/
blob-report/
.codeyam/llm-calls/
.codeyam/captures/
.codeyam/results/
.codeyam/tmp/
.codeyam/build-agent-handoff.md
.codeyam/build-agent-session.json
.codeyam/claude-session-id.txt
.codeyam/editor-mode-context.md
.codeyam/dev-mode-context.md
.codeyam/editor-step.json
.codeyam/editor-step.json.bak
.codeyam/editor-task-tracking.json
.codeyam/editor-pending-plan.json
.codeyam/feature-finalized.json
.codeyam/editor-user-prompt.txt
.codeyam/preview-shown.json
.codeyam/preview-state.json
.codeyam/preview-env.json
.codeyam/preview-capture.png
.codeyam/server-state.json

# codeyam-editor:start
# Managed by `codeyam-editor init` / `codeyam-editor start`.
# Do not edit between these markers — your changes will be overwritten.
.codeyam/run/
.codeyam/tmp/
.codeyam/logs/
.codeyam/captures/
.codeyam/results/
.codeyam/_legacy/
.codeyam/preview-state.json
.codeyam/preview-env.json
.codeyam/preview-capture.png
.codeyam/preview-capture.*.png
.codeyam/results-shown.json
.codeyam/build-agent-handoff.md
.codeyam/editor-step.json
.codeyam/editor-user-prompt.txt
.codeyam/editor-pending-plan.json
.codeyam/recent-runs.json
# Per-clone session start state (sessionId/startedAtSha), read only locally by
# the authorship check — never read from a commit, so it must not be shared.
# Tracking it makes it conflict on every rebase; untracking removes the problem.
.codeyam/session-marker.json
.codeyam/editor.local.json
.codeyam/cloud.json
# codeyam-editor:end
